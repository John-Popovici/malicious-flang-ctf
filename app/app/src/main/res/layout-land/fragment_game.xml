<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.fragment.GameFragment">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_gravity="center">


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/player1InfoParent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:background="?android:selectableItemBackground"
                        android:layout_margin="10dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/player1Title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                                android:text="GM"
                                android:layout_marginEnd="4dp"
                                android:textColor="@color/green_400"
                                android:visibility="gone"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/player1Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Player 1"
                                android:textAppearance="@style/TextAppearance.AppCompat.Medium" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/player1Rating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="\?" />

                            <TextView
                                android:id="@+id/player1RatingDiff"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="2dp"
                                android:layout_marginRight="2dp"
                                android:text="+2"
                                android:visibility="invisible"
                                android:textColor="@color/ratingDiffPositive"
                                android:textStyle="bold" />

                        </LinearLayout>
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/player1TimeParent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:background="@color/fieldSelected">

                        <TextView
                            android:id="@+id/player1Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_margin="10dp"
                            android:text="00:00"
                            android:textAppearance="@style/TextAppearance.AppCompat.Large"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="bottom|right">

                    <LinearLayout
                        android:id="@+id/player2InfoParent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:layout_gravity="center_vertical"
                        android:background="?android:selectableItemBackground"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/player2Title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                                android:text="GM"
                                android:layout_marginEnd="4dp"
                                android:textColor="@color/green_400"
                                android:visibility="gone"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/player2Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Player 2"
                                android:textAppearance="@style/TextAppearance.AppCompat.Medium" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/player2Rating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="\?" />

                            <TextView
                                android:id="@+id/player2RatingDiff"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="2dp"
                                android:layout_marginRight="2dp"
                                android:text="+2"
                                android:visibility="invisible"
                                android:textColor="@color/ratingDiffPositive"
                                android:textStyle="bold" />

                        </LinearLayout>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_margin="10dp"
                        android:id="@+id/player2TimeParent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/fieldSelected">

                        <TextView
                            android:id="@+id/player2Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_margin="10dp"
                            android:text="00:00"
                            android:textAppearance="@style/TextAppearance.AppCompat.Large"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                </LinearLayout>

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:orientation="horizontal">

                    <include
                        android:id="@+id/mainBoard"
                        layout="@layout/board_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="center" />
                </FrameLayout>

            </FrameLayout>

            <LinearLayout
                android:id="@+id/gameAdditionalContentParent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:layout_weight="1"
                android:orientation="vertical">

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/spectatorCountRoot"
            android:visibility="invisible"
            android:layout_margin="10dp">

            <TextView
                android:id="@+id/spectatorCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                app:tint="?android:textColorSecondary"
                android:src="@drawable/ic_spectator" />
        </LinearLayout>

        <TextView
            android:id="@+id/positionName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:layout_margin="10dp"
            android:layout_gravity="end" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/resignButton"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="@string/actionResign"
            app:srcCompat="@drawable/ic_resign"
            app:tint="?android:textColorSecondary" />

        <ImageView
            android:id="@+id/shareButton"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="@string/actionShare"
            app:srcCompat="@drawable/ic_share"
            app:tint="?android:textColorSecondary" />

        <ImageView
            android:id="@+id/swapSidesButton"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="@string/actionShare"
            app:srcCompat="@drawable/ic_swap"
            app:tint="?android:textColorSecondary" />

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="@string/actionBack"
            app:srcCompat="@drawable/ic_left"
            app:tint="?android:textColorSecondary" />

        <ImageView
            android:id="@+id/forwardButton"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="@string/actionForward"
            app:srcCompat="@drawable/ic_right"
            app:tint="?android:textColorSecondary" />

        <ImageView
            android:id="@+id/analysisButton"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="@string/analysisTitle"
            app:srcCompat="@drawable/ic_analysis"
            app:tint="?android:textColorSecondary" />

        <ImageView
            android:id="@+id/hintButton"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="@string/computerHint"
            app:srcCompat="@drawable/ic_hint"
            app:tint="?android:textColorSecondary" />

        <ImageView
            android:id="@+id/openingDatabaseToggleButton"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="@string/computerHint"
            app:srcCompat="@drawable/ic_book"
            app:tint="?android:textColorSecondary" />

        <Button
            android:id="@+id/abstractButton"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right"
            android:layout_margin="10dp"
            android:text="@string/tutorialNext"
            android:visibility="gone"
            app:icon="@drawable/ic_right"
            app:srcCompat="@drawable/ic_right"
            app:tint="?android:textColorSecondary" />

        <ImageView
            android:id="@+id/computerAnalysisButton"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:visibility="gone"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="@string/computerAnalysis"
            app:srcCompat="@drawable/ic_computer_analysis"
            app:tint="?android:textColorSecondary" />

    </LinearLayout>

</LinearLayout>